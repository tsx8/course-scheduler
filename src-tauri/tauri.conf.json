{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "course-scheduler",
  "version": "0.1.0",
  "identifier": "com.tsxb.course-scheduler",
  "build": {
    "beforeDevCommand": "npm run build:solver && npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build:solver && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "course-scheduler",
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/solver"
    ]
  }
}